# ============================================================
# ARDP Production Environment Variables
# Copy to .env on EC2 and fill in real values.
# NEVER commit the real .env to git.
# ============================================================

# API security
ARDP_API_KEY=change-me-strong-random-key

# Pipeline mode: demo | production
ARDP_MODE=production

# Kafka (only needed in full-stack mode; not used in demo mode)
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=net.flows

# Redis (local to EC2 in free-tier mode)
REDIS_URL=redis://redis:6379

# MLflow (SQLite backend for free-tier)
MLFLOW_TRACKING_URI=sqlite:///mlruns/mlflow.db

# Conformal prediction
CONFORMAL_ALPHA=0.05
RSCP_SIGMA=0.1

# Drift
DRIFT_CONSENSUS=2

# Lambda health check alerts (optional SNS topic)
SNS_TOPIC_ARN=

# AWS region
AWS_DEFAULT_REGION=us-east-1
